# NarraVox — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local — ele já está coberto pelo .gitignore.
#
# Documentação detalhada: docs/env-vars.md

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obter em: https://supabase.com/dashboard → seu projeto → Settings → API

# URL pública do projeto (pode aparecer no browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Chave anon — projetada para ser pública, usada no cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role — SECRET, NUNCA expor ao browser ou commitar
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin ───────────────────────────────────────────────────────────────────
# Emails separados por vírgula com acesso ao painel /admin
ADMIN_EMAILS=seu@email.com

# ─── Site ────────────────────────────────────────────────────────────────────
# URL base do site — necessário para links de email (confirmação, reset de senha)
# Em desenvolvimento: deixar vazio ou http://localhost:3001
# Em produção: URL real do deploy (ex: https://narravox.vercel.app)
NEXT_PUBLIC_SITE_URL=
